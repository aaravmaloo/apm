{
  "schema_version": "1.0",
  "name": "clip_auto_clear",
  "version": "1.0.0",
  "description": "Copy text and auto-clear clipboard after delay",
  "author": "APM",
  "permissions": [
    "system.write"
  ],
  "file_storage": {
    "enabled": false,
    "allowed_types": []
  },
  "commands": {
    "copy": {
      "description": "Copy text and clear it after N seconds",
      "flags": {
        "text": {
          "type": "string",
          "default": ""
        },
        "seconds": {
          "type": "number",
          "default": "10"
        }
      },
      "steps": [
        {
          "op": "s:clip",
          "args": [
            "{{text}}"
          ]
        },
        {
          "op": "s:sleep",
          "args": [
            "{{seconds}}"
          ]
        },
        {
          "op": "s:clip",
          "args": [
            ""
          ]
        }
      ]
    }
  },
  "hooks": {}
}
